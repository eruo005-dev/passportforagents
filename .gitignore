# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# throwaway test signing key for the spec fixtures — never commit private keys
spec/fixtures/keypair.json
spec/fixtures/self-keypair.json

# vercel
.vercel

# package build output
/packages/*/dist

# typescript
*.tsbuildinfo
next-env.d.ts

# private signing keys — never commit any *.SECRET.json
*.SECRET.json

# internal docs / agent config — kept local, not in the public repo
/CLAUDE.md
/PROGRESS.md
/RESEARCH.md
/WORKING_AGREEMENT.md
/.claude/

# agoramind showcase artifacts (private key must not be committed)
agoramind-passport-key.SECRET.json
.devlive.log
agoramind-agent-passport.json

.vercel

# local audit artifacts
lh-*.json
psi-*.json
