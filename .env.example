# ──────────────────────────────────────────────────────────────────────────
# PassportForAgents — environment template.
# Copy to `.env.local` and fill in. `.env.local` is gitignored; never commit secrets.
# ──────────────────────────────────────────────────────────────────────────

# --- Database (Supabase Postgres, via Drizzle) ------------------------------
# Runtime serverless queries → Supabase transaction pooler (PgBouncer, :6543).
# The app sets prepare:false because transaction-mode pooling disallows
# prepared statements.
DATABASE_URL="postgres://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"

# Migrations / drizzle-kit → session connection (:5432, no pgbouncer).
DIRECT_URL="postgres://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# Supabase client (browser + server)
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# server-only secrets
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""

# --- Clerk (auth — GitHub + Email) ------------------------------------------
# Create an app at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Later sprints ----------------------------------------------------------
# RESEND_API_KEY=""              # Sprint 2 — verification emails (https://resend.com)
# GITHUB_TOKEN=""                # Sprint 2 — repo-based verification
# STRIPE_SECRET_KEY=""           # Sprint 5 — billing (https://dashboard.stripe.com)
# STRIPE_WEBHOOK_SECRET=""       # Sprint 5
